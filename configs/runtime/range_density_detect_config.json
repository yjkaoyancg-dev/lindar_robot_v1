{
    "topic_name": "/pointcloud_BAX49K59",
    "output_pose_topic": "/robot_info_range",
    "output_detected_topic": "/range_detector/detected",
    "output_confidence_topic": "/range_detector/confidence",
    "output_target_cloud_topic": "/range_detector/target_cloud",
    "output_marker_topic": "/range_detector/marker",

    "publish_target_cloud": true,
    "publish_marker": true,

    "scan_axis": "x",
    "near_to_far": true,

    "voxel_size": 0.05,

    "roi_x_min": 5.0,
    "roi_x_max": 45.0,
    "roi_y_min": -10.0,
    "roi_y_max": 10.0,
    "roi_z_min": -10.0,
    "roi_z_max": 10.0,

    "bin_min": 5.0,
    "bin_max": 45.0,
    "bin_size": 0.20,

    "smooth_window": 3,
    "min_points_per_bin": 5,
    "min_consecutive_bins": 1,
    "max_consecutive_bins": 30,

    "max_y_std": 10.0,
    "max_z_std": 10.0,

    "min_total_points": 10,
    "confidence_ref_points": 100,

    "save_debug_profile": true,
    "debug_profile_path": "/tmp/range_density_profile.csv"
}
